# ─────────────────────────────────────────────────────────────────────────────
# zama-indexer environment. Copy to .env.local and fill in. Never commit a key.
# Local-only: Anvil + forge-fhevm; decryption via the SDK's cleartext() transport.
# Zero-config — every value below has a sensible local default, so an empty
# .env.local works once the local stack is deployed (`pnpm local:deploy`).
# ─────────────────────────────────────────────────────────────────────────────

# RPC for the local node (Ponder + the SDK). Defaults to http://127.0.0.1:8545.
# PONDER_RPC_URL_31337=http://127.0.0.1:8545

# The ERC-7984 confidential token the indexer watches. Written automatically by
# `pnpm local:deploy` (scripts/write-env.mjs) from the deploy output.
CONFIDENTIAL_TOKEN_ADDRESS=

# Holder/delegate EOA. Defaults to Anvil account #0 (a public dev key), so you can
# leave it blank. Set it to index a different holder.
# PRIVATE_KEY=

# ── Optional overrides (rarely needed) ───────────────────────────────────────
# Explicit RPC for the SDK in tests (overrides the local default).
# SDK_RPC_URL=http://127.0.0.1:8545
# ACL contract. Defaults to forge-fhevm's canonical local ACL.
# ACL_ADDRESS=
# fhEVM executor (cleartext transport). Defaults to the SDK hardhat-preset address.
# EXECUTOR_ADDRESS=
# Block to start indexing from (default 0 locally).
# START_BLOCK=
# ACL_START_BLOCK=
# Postgres connection string. Falls back to embedded SQLite (PGlite) when unset.
# DATABASE_URL=
