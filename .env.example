# ─────────────────────────────────────────────────────────────────────────────
# zama-indexer environment. Copy to .env.local and fill in. Never commit a key.
#
# Two modes (see ponder.config.ts / src/lib/zama.ts):
#   MODE unset / "local"  → Anvil + forge-fhevm; decryption via the SDK's cleartext()
#                           transport. Zero-config: sensible local defaults below.
#   MODE=sepolia          → Sepolia + the hosted relayer (node()). Fill the Sepolia vars.
# ─────────────────────────────────────────────────────────────────────────────

# Which stack to run against. Defaults to local when unset.
# MODE=sepolia

# ── Local (Anvil + forge-fhevm) ──────────────────────────────────────────────
# RPC for the local node (Ponder + the SDK). Defaults to http://127.0.0.1:8545.
# PONDER_RPC_URL_31337=http://127.0.0.1:8545

# The ERC-7984 confidential token the indexer watches. In local mode this is written
# automatically by `pnpm local:deploy` (via scripts/write-env.mjs) from the deploy output.
CONFIDENTIAL_TOKEN_ADDRESS=

# Holder/delegate EOA. In local mode defaults to Anvil account #0 (a public dev key),
# so you can leave it blank. Set it to index a different holder.
# PRIVATE_KEY=

# ── Sepolia (hosted relayer) ─────────────────────────────────────────────────
# Sepolia RPC (chain 11155111) for Ponder.
# PONDER_RPC_URL_11155111=
# Sepolia RPC for the SDK's viem client (may equal the above).
# SEPOLIA_RPC_URL=
# Relayer API key — optional on Sepolia testnet, required on mainnet.
# RELAYER_API_KEY=

# ── Optional overrides (rarely needed) ───────────────────────────────────────
# Explicit RPC for the SDK and tests (overrides the derived default above).
# SDK_RPC_URL=http://127.0.0.1:8545
# ACL contract address. Defaults to the canonical address per chain (forge-fhevm local
# ACL, or the SDK Sepolia preset). Override only for a non-standard deployment.
# ACL_ADDRESS=
# fhEVM executor address (local cleartext transport). Defaults to the forge-fhevm /
# hardhat-preset canonical address. Override only for a non-standard host deployment.
# EXECUTOR_ADDRESS=
# Block to start indexing from (default 0 locally; the token's deploy block on Sepolia).
# START_BLOCK=
# ACL_START_BLOCK=
# Postgres connection string. Falls back to embedded SQLite (PGlite) when unset.
# DATABASE_URL=
