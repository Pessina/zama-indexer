# ── Ponder indexer ────────────────────────────────────────────────
# Sepolia RPC URL (chain id 11155111). Alchemy, Infura, or any node.
PONDER_RPC_URL_11155111=

# Optional Postgres connection string. Falls back to embedded SQLite if unset.
# DATABASE_URL=

# ── Zama SDK / decryption ─────────────────────────────────────────
# RPC endpoint for the SDK's viem client (may equal PONDER_RPC_URL_11155111).
SEPOLIA_RPC_URL=

# Private key of the indexer's holder/delegate EOA. TEST KEY ONLY — never commit a real key.
PRIVATE_KEY=

# The ERC-7984 confidential token to index (or its underlying ERC-20; the SDK
# resolves the confidential wrapper via the on-chain registry).
TOKEN_ADDRESS=

# Relayer API key — optional on Sepolia testnet, required on mainnet.
# RELAYER_API_KEY=
