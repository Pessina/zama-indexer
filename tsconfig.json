{
  "compilerOptions": {
    // Type checking
    "strict": true,
    "noUncheckedIndexedAccess": true,

    // Interop constraints
    "verbatimModuleSyntax": false,
    "esModuleInterop": true,
    "isolatedModules": true,
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,

    // Language and environment
    "moduleResolution": "bundler",
    "module": "ESNext",
    "noEmit": true,
    "lib": ["ES2022"],
    "target": "ES2022",

    // Skip type checking for node modules
    "skipLibCheck": true
  },
  "include": ["./**/*.ts"],
  // `contracts/` is a separate Foundry project; its vendored Solidity deps ship their own
  // TypeScript tests, which are not part of this service. Keep tsc on our code only.
  "exclude": ["node_modules", "contracts", "generated", ".ponder"]
}
